{
  "name": "@tarcisiojr/cli",
  "version": "0.2.0",
  "type": "module",
  "description": "CLI para o AI Toolkit — gerenciador de pacotes para artefatos de AI coding tools (skills, MCPs, templates, configs, hooks).",
  "bin": {
    "aitk": "./dist/bin/aitk.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/__tests__",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tarcisiojr/ai-toolkit",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/tarcisiojr/ai-toolkit#readme",
  "bugs": {
    "url": "https://github.com/tarcisiojr/ai-toolkit/issues"
  },
  "license": "MIT",
  "keywords": [
    "ai-toolkit",
    "aitk",
    "ai",
    "coding-tools",
    "claude-code",
    "opencode",
    "gemini-cli",
    "skills",
    "mcp",
    "templates",
    "cli",
    "registry",
    "package-manager"
  ],
  "author": "tarcisiojr",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@tarcisiojr/shared": "0.2.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "inquirer": "^12.4.2",
    "ora": "^8.2.0",
    "semver": "^7.7.4",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.13.10",
    "@types/semver": "^7.7.1",
    "@types/tar": "^6.1.13",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.22.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}
