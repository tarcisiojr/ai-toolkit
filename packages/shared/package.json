{
  "name": "@ai-toolkit/shared",
  "version": "0.1.0",
  "type": "module",
  "description": "Tipos e validadores compartilhados do AI Toolkit — registry de artefatos para AI coding tools.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tarcisiojr/ai-toolkit",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/tarcisiojr/ai-toolkit#readme",
  "bugs": {
    "url": "https://github.com/tarcisiojr/ai-toolkit/issues"
  },
  "license": "MIT",
  "keywords": [
    "ai-toolkit",
    "ai",
    "coding-tools",
    "types",
    "validators",
    "shared"
  ],
  "author": "tarcisiojr",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.22.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}
